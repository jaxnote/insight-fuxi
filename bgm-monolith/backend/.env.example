# ── 本地开发环境变量模板 ──────────────────────────────────────────────────────
# 复制本文件为 .env，填入真实值后使用（.env 已加入 .gitignore，不会被提交）

# 数据库（异步 MySQL 驱动：mysql+aiomysql）
DATABASE_URL=mysql+aiomysql://<user>:<password>@<host>:3306/<db_name>

APP_NAME=insight-fuxi
VERSION=0.1.0
DEBUG=true

# 存储后端：mysql | sqlite
CONVERSATION_BACKEND=mysql
# 文件后端：local | s3
FILE_BACKEND=local
STORAGE_BASE_PATH=./storage

# Agent 网关（OpenClaw）
OPENCLAW_API_URL=http://localhost:8001
OPENCLAW_API_KEY=
